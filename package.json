{
  "name": "agentic-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Context-aware workspace for local coding-agent experiments and microservice validation.",
  "scripts": {
    "setup:8gb": "AGENTIC_PROFILE=8gb bash local-agents/setup.sh",
    "agent:8gb": "bash local-agents/run-agent.sh",
    "setup:16gb": "AGENTIC_PROFILE=16gb bash local-agents/setup.sh",
    "agent:16gb": "AGENTIC_PROFILE=16gb bash local-agents/run-agent.sh",
    "setup:low-memory": "AGENTIC_PROFILE=low-memory bash local-agents/setup.sh",
    "agent:low-memory": "AGENTIC_PROFILE=low-memory bash local-agents/run-agent.sh",
    "context:report": "python3 scripts/context_efficiency_report.py",
    "context:api-test": "python3 scripts/context_efficiency_report.py --task-profile api-test-change",
    "context:new-endpoint": "python3 scripts/context_efficiency_report.py --task-profile new-endpoint-change",
    "context:shared-qa": "python3 scripts/context_efficiency_report.py --task-profile shared-qa-utility-change",
    "context:walkthrough": "python3 scripts/context_efficiency_report.py --task-profile business-flow-walkthrough",
    "metrics:8gb": "python3 local-agents/token-metrics-dashboard.py --llama-url http://localhost:8080 --port 8765",
    "metrics:16gb": "python3 local-agents/token-metrics-dashboard.py --llama-url http://localhost:8080 --port 8765",
    "metrics:custom": "python3 local-agents/token-metrics-dashboard.py",
    "agent:doctor": "python3 local-agents/check-tool-calls.py --base-url http://localhost:8080/v1 --model local-model",
    "models:profiles": "cat local-agents/config/model-profiles.json",
    "models:8gb": "AGENTIC_PROFILE=8gb python3 local-agents/render-pi-models.py --profile 8gb --output /tmp/agentic-pi-models-8gb.json && cat /tmp/agentic-pi-models-8gb.json",
    "docs:models": "sed -n '1,220p' docs/local-agent-runtime.md"
  }
}
